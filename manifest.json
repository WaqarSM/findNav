{
  "manifest_version": 3,
  "name": "FindNav",
  "version": "0.1.0",
  "description": "Find text on a page, prioritize links and controls, and activate matches from the keyboard.",
  "permissions": ["activeTab"],
  "action": {
    "default_title": "FindNav",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ]
}
